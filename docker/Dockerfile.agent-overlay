# 基于官方 SWE-bench 镜像添加 Agent 工具
# 使用方式: docker build --build-arg BASE_IMAGE=swebench/sweb.eval.x86_64.xxx -t xxx-agent -f Dockerfile.agent-overlay .

ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# 安装 Node.js 20.x LTS
RUN apt-get update && apt-get install -y curl gnupg ca-certificates \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# 安装 Claude Code 和 Codex CLI
RUN npm install -g @anthropic-ai/claude-code @openai/codex

# 创建配置目录
RUN mkdir -p /root/.claude /root/.codex

# 复制配置文件
COPY settings.json /root/.claude/settings.json
COPY auth.json /root/.codex/auth.json
COPY config.toml /root/.codex/config.toml

