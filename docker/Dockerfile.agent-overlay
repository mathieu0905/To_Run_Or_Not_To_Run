# Add Agent tools on top of official SWE-bench image
# Usage: docker build --build-arg BASE_IMAGE=swebench/sweb.eval.x86_64.xxx -t xxx-agent -f Dockerfile.agent-overlay .

ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# Install Node.js 20.x LTS
RUN apt-get update && apt-get install -y curl gnupg ca-certificates \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code and Codex CLI
RUN npm install -g @anthropic-ai/claude-code @openai/codex

# Install OpenCode CLI (standalone binary)
RUN curl -fsSL https://raw.githubusercontent.com/opencode-ai/opencode/refs/heads/main/install | bash \
    && ln -sf /root/.opencode/bin/opencode /usr/local/bin/opencode

# Create configuration directories. Runtime credentials are passed with
# docker -e by experiments/agent_caller.py; do not bake secrets into images.
RUN mkdir -p /root/.claude /root/.codex

# Set non-secret defaults
ENV ANTHROPIC_BASE_URL=https://api.anthropic.com
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ENV API_TIMEOUT_MS=600000

WORKDIR /testbed
