# Run-Free/Run-Less/Run-Full Research Project Base Image
# Based on SWE-bench Python base image, with node, codex, and claude code added

FROM --platform=linux/x86_64 ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

# Proxy configuration
ENV http_proxy=http://127.0.0.1:15732
ENV https_proxy=http://127.0.0.1:15732
ENV HTTP_PROXY=http://127.0.0.1:15732
ENV HTTPS_PROXY=http://127.0.0.1:15732

# Basic dependencies
RUN apt update && apt install -y \
    wget \
    git \
    build-essential \
    libffi-dev \
    libtiff-dev \
    python3 \
    python3-pip \
    python-is-python3 \
    jq \
    curl \
    locales \
    locales-all \
    tzdata \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (LTS)
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list \
    && apt update \
    && apt install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Miniconda
RUN wget 'https://repo.anaconda.com/miniconda/Miniconda3-py311_24.5.0-0-Linux-x86_64.sh' -O miniconda.sh \
    && bash miniconda.sh -b -p /opt/miniconda3 \
    && rm miniconda.sh

ENV PATH=/opt/miniconda3/bin:$PATH

RUN conda init --all \
    && conda config --append channels conda-forge

# Install Claude Code (via npm)
RUN npm install -g @anthropic-ai/claude-code

# Install Codex (OpenAI)
RUN npm install -g @openai/codex

# Create non-root user
RUN adduser --disabled-password --gecos 'dog' nonroot

# Create configuration directories
RUN mkdir -p /root/.claude /root/.codex

# Working directory
WORKDIR /testbed/

# Bashrc configuration for activating conda environment
RUN echo "source /opt/miniconda3/etc/profile.d/conda.sh" >> /root/.bashrc
